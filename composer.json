{
    "name": "fabpot/json-rpc-peer",
    "type": "library",
    "description": "An asynchronous, bidirectional JSON-RPC 2.0 peer over line-delimited streams, built on amphp",
    "keywords": ["json-rpc", "jsonrpc", "async", "amphp", "stdio", "lsp", "mcp"],
    "license": "MIT",
    "authors": [
        {
            "name": "Fabien Potencier",
            "email": "fabien@symfony.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "amphp/byte-stream": "^2"
    },
    "require-dev": {
        "phpunit/phpunit": "^12",
        "phpstan/phpstan": "^2.1",
        "php-cs-fixer/shim": "^3.93",
        "psr/log": "^1.1|^2|^3"
    },
    "suggest": {
        "psr/log": "To forward JSON-RPC traffic to a PSR-3 logger."
    },
    "autoload": {
        "psr-4": {
            "Fabpot\\JsonRpc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fabpot\\JsonRpc\\Tests\\": "tests/"
        }
    }
}
